# ===========================================
# filmott 프로덕션 환경변수 템플릿
# 이 파일을 backend/.env.production으로 복사한 뒤 실제 값을 입력하세요.
# ===========================================

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=

# CORS
CORS_ORIGIN=https://filmott.kr

# Admin Seed
ADMIN_NICKNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# External APIs
TMDB_API_KEY=
KOBIS_API_KEY=

# Social Login - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://filmott.kr/api/auth/google/callback

# Social Login - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=https://filmott.kr/api/auth/kakao/callback

# Social Login - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=https://filmott.kr/api/auth/naver/callback

# Frontend URL
FRONTEND_URL=https://filmott.kr

# Google Analytics (docker-compose.prod.yml build args에서 사용)
NEXT_PUBLIC_GA_ID=
